package main

import (
	"AutoPartPro/internal/models"
	"AutoPartPro/internal/repository"
	"fmt"
)

func main() {
	// 1. إنشاء المخزن
	repo := repository.NewInventoryRepository()

	// 2. إضافة قطعة تجريبية
	newPart := models.Part{
		ID:    "1",
		Name:  "مساعد سيارة",
		SKU:   "SP-100",
		Price: 150.5,
		Stock: 10,
	}
	repo.AddPart(newPart)

	// 3. اختبار جلب القطعة
	part, exists := repo.GetPart("1")
	if exists {
		fmt.Printf("تم العثور على القطعة: %s، السعر: %.2f ريال\n", part.Name, part.Price)
	} else {
		fmt.Println("القطعة غير موجودة!")
	}
}
