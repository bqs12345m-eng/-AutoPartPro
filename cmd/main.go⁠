package main

import (
	"fmt"
	"log"
	"net/http"
)

func main() {
	// ترحيب بنظام المخزون
	http.HandleFunc("/inventory", func(w http.ResponseWriter, r *http.Request) {
		fmt.Fprintf(w, "AutoPartPro: Inventory Service is Online!")
	})

	log.Println("Inventory Service running on port 8080...")
	log.Fatal(http.ListenAndServe(":8080", nil))
}
